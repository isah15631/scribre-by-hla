# ============================================================
# Scribre by HLA - environment variables
# ============================================================
# Copy this file to ".env" for local development and fill in your key.
# In deployment, set these in the host's dashboard (Render / Netlify), NOT here.

# ----- BACKEND (the Express server: Render / your own host) -----

# Your Google Gemini API key. Get one free at https://aistudio.google.com/apikey
# Required. The server reads process.env.GEMINI_API_KEY.
GEMINI_API_KEY="your-gemini-api-key-here"

# Optional: lock cross-origin access to your frontend's origin.
# Defaults to "*" (any origin) if unset. Example:
# ALLOWED_ORIGIN="https://your-site.netlify.app"

# NODE_ENV: set to "production" on your deploy host so the server serves the
# built frontend instead of starting Vite. (Render sets this via render.yaml.)
# NODE_ENV="production"

# ----- FRONTEND (build-time; only needed if hosted SEPARATELY, e.g. Netlify) -----

# Point the frontend at the backend's public URL. Leave UNSET for local dev or a
# single-host deploy (where the same server serves the frontend). Example:
# VITE_API_BASE_URL="https://scribre-api.onrender.com"
